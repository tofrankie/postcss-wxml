{
  "name": "@tofrankie/postcss-wxml",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "description": "PostCSS syntax for parsing WXML",
  "author": "Frankie <1426203851@qq.com> (https://github.com/tofrankie)",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/postcss-wxml",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/postcss-wxml.git"
  },
  "bugs": "https://github.com/tofrankie/postcss-wxml/issues",
  "keywords": [
    "postcss",
    "stylelint",
    "wxml",
    "wxs",
    "miniprogram",
    "postcss-wxml",
    "postcss-html",
    "tofrankie"
  ],
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm lint && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "run-s lint:eslint lint:prettier typecheck",
    "lint:eslint": "eslint . --cache --fix",
    "lint:prettier": "prettier . --cache --write --log-level silent",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "prepare": "husky",
    "github:release": "tfr"
  },
  "dependencies": {
    "htmlparser2": "^12.0.0",
    "postcss": "^8.5.8"
  },
  "devDependencies": {
    "@tofrankie/action": "^0.0.5",
    "@tofrankie/eslint": "^0.0.17",
    "@tofrankie/prettier": "^0.0.11",
    "@tofrankie/tsconfig": "^0.0.4",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "stylelint": "^17.6.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
